# ========================================
# Music App 环境变量配置
# ========================================
# 复制此文件为 .env 并填入你的实际值
# 不配置 Supabase 时，应用自动使用本地模拟数据

# Supabase 配置（在 https://supabase.com 创建项目后获取）
VITE_SUPABASE_URL=https://你的项目ID.supabase.co
VITE_SUPABASE_ANON_KEY=你的匿名Key

# 可选：应用标题
VITE_APP_TITLE=MySpace Music
